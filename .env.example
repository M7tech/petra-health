# Copy to .env and adjust. Loaded by apps/api (Prisma + Nest config).
DATABASE_URL="postgresql://petra:petra_dev_pw@localhost:5432/petra_health?schema=public"

# Auth
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# API
API_PORT=3001
CORS_ORIGINS="http://localhost:3000,http://localhost:8081"

# Web (apps/web/.env.local): NEXT_PUBLIC_API_URL="http://localhost:3001"
# Mobile (apps/mobile/.env): EXPO_PUBLIC_API_URL="http://localhost:3001"
